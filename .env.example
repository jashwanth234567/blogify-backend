# .env.example
# Copy this file to .env and fill in the actual values

# JWT Secret – secret used to sign JWT tokens
JWT_SECRET=your_jwt_secret

# Admin Credentials – email address for admin user
ADMIN_EMAIL=admin@example.com

# MongoDB Atlas connection string
MONGODB_URI=your_mongodb_connection_string

# Gemini AI API key
GEMINI_API_KEY=your_gemini_api_key

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_email_address
SMTP_PASS=your_smtp_password

# Email sender address used in outgoing mails
EMAIL_FROM=no-reply@blogify.com

# Client URL – set to the live front‑end URL when deployed
CLIENT_URL=https://blogify-backend1.onrender.com
